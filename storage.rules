rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Event assets are stored under a path that encodes the owning user's UID.
    // Reads are public (event banners / logos need to load for anyone visiting
    // the event page).  Writes and deletes are restricted to the UID that owns
    // the path, enforced by comparing request.auth.uid against the {uid} wildcard.
    match /event-assets/{uid}/{eventId}/{assetType}/{filename} {
      allow read:   if true;
      allow write:  if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.size <= 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Organizer branding assets: logo, certificate signature, email header.
    // Stored as organizer-assets/{uid}/{assetType}.{ext}.
    // Reads are public so branding images load on event pages and certificates.
    // Writes and deletes are scoped to the owning organizer.
    match /organizer-assets/{uid}/{filename} {
      allow read:   if true;
      allow write:  if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.size <= 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Certificate template files (PDF / PNG / JPG) AND builder assets (logo /
    // signature / seal images under .../assets/...), uploaded by organizers.
    // Stored under certificates/templates/{uid}/{eventId}/** — {allPaths=**}
    // covers both the top-level template file and nested asset files.
    // Owner-only read/write/delete (templates are private designs, not public
    // assets). The server fetches files via their download token, which works
    // regardless of these read rules. Per-type size limits: PDF 25 MB, image 10 MB.
    match /certificates/templates/{uid}/{eventId}/{allPaths=**} {
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow write:  if request.auth != null
                    && request.auth.uid == uid
                    && (
                      (request.resource.contentType == 'application/pdf'
                        && request.resource.size <= 25 * 1024 * 1024)
                      || (request.resource.contentType.matches('image/(jpeg|png)')
                        && request.resource.size <= 10 * 1024 * 1024)
                    );
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else.  This is belt-and-suspenders: Firebase Storage
    // has no implicit deny, so an explicit wildcard deny is required to ensure
    // unauthenticated and mis-pathed writes cannot succeed.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
